# Copy to .env and fill in.

# Required for the real pipeline and the LLM chemistry guard.
# Not needed when USE_STUB_PIPELINE=true (stub guard accepts any non-empty query).
OPENAI_API_KEY=

# Pipeline mode: true = credential-free demo (stub pipeline + stub guard).
# The real pipeline arrives in Phase 2.
USE_STUB_PIPELINE=false

# Langfuse (LLM cost tracking) — optional.
# Both keys empty => tracking disabled and the service behaves exactly as before.
# Get keys from a Langfuse Cloud project (or your self-hosted instance).
# Chat-completion cost (narration, scene-split, guard) is tracked automatically;
# TTS/Whisper appear as generations but show $0 until you set those models'
# prices in the Langfuse UI (Settings -> Models).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Models
# Scene split must copy the transcript word for word. gpt-4o-mini drops whole
# sentences on that task (alignment then rejects the split and the job fails),
# so gpt-4o is the default here — as in the original generate-script-tech.mjs.
LLM_MODEL=gpt-4o
# Warm enough to write well, cool enough to obey the verbatim rule. Unset,
# OpenAI defaults to 1.0, which paraphrases and drops clauses.
LLM_TEMPERATURE=0.5
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TRANSCRIBE_MODEL=whisper-1

# Narration language. DEFAULT_LANGUAGE is used when a request omits `language`.
# TTS_VOICE_BY_LANGUAGE picks a voice per language (JSON); unmapped languages
# fall back to TTS_VOICE. All gpt-4o-mini-tts voices are multilingual.
DEFAULT_LANGUAGE=en
TTS_VOICE_BY_LANGUAGE={"en":"alloy","vi":"alloy"}

# Paths
HYPERFRAMES_DIR=./render_kit
ARTIFACTS_DIR=./artifacts

# Tuning
WORKER_CONCURRENCY=1
MAX_RETRIES=3
# Rendering runs at roughly 2x realtime at 1080p (plus lint/validate/inspect),
# so a 5-min horizontal video takes ~10 min and a 10-min one ~20+. Too low and
# a finished render gets killed at the line and the job is marked FAILED.
RENDER_TIMEOUT_SECONDS=1800

# Long-form (orientation=horizontal). Scripts over TTS_MAX_CHARS are split at
# sentence boundaries, synthesized per chunk, and ffmpeg-joined into one
# narration.mp3 — so ffmpeg must be on PATH for long-form jobs.
TTS_MAX_CHARS=4000
# Content-validation attempts per scene-split section before failing the job.
MAX_SPLIT_ATTEMPTS=4

# Rounds of (align -> compose -> layout gate). Each failure re-splits only the
# section(s) owning the offending scenes and tries again; exhausting the rounds
# fails the job. The gate only blocks on ERROR-severity layout findings (text
# clipped/occluded/overflowing its box) — those are layouts hyperframes cannot
# render. Warnings render fine and are ignored.
OUTER_RETRY_LIMIT=3
LAYOUT_GATE_TIMEOUT_SECONDS=300

# Admin login (optional). Both unset => auth DISABLED with a startup warning
# (dev/stub mode). Set both to require a Bearer token on the videos API
# (POST /api/v1/auth/login exchanges these credentials for a 24h token).
ADMIN_USERNAME=
ADMIN_PASSWORD=
# HMAC key for admin session tokens; defaults to ADMIN_PASSWORD.
AUTH_SECRET=
# Session token lifetime (seconds); default 24h.
ADMIN_SESSION_TTL_SECONDS=86400

# Browser client (frontend/). Comma-separated origins allowed via CORS.
CORS_ORIGINS=http://localhost:5173
# Where the OAuth callback redirects the browser (tokens in the URL fragment)
# when login was started with ?mode=web.
FRONTEND_OAUTH_REDIRECT=http://localhost:5173/oauth/callback

# YouTube upload (optional). Create an OAuth client in Google Cloud Console:
# type "Web application", enable the YouTube Data API v3, and register
# GOOGLE_REDIRECT_URI verbatim under "Authorized redirect URIs". Unset, the
# /api/v1/auth/google endpoints return 500 and everything else still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# HMAC key for the OAuth state param; defaults to GOOGLE_CLIENT_SECRET.
OAUTH_STATE_SECRET=
# Resumable upload chunk size (must be a multiple of 256 KiB) and per-call
# read timeout for Google requests.
YOUTUBE_UPLOAD_CHUNK_BYTES=8388608
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=600
