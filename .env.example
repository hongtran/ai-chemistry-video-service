# Copy to .env and fill in.

# Required for the real pipeline and the LLM chemistry guard.
# Not needed when USE_STUB_PIPELINE=true (stub guard accepts any non-empty query).
OPENAI_API_KEY=

# Pipeline mode: true = credential-free demo (stub pipeline + stub guard).
# The real pipeline arrives in Phase 2.
USE_STUB_PIPELINE=true

# Models
LLM_MODEL=gpt-4o-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TRANSCRIBE_MODEL=whisper-1

# Paths
HYPERFRAMES_DIR=./render_kit
SCENE_SCHEMA_PATH=./schemas/scene_schema.json
ARTIFACTS_DIR=./artifacts

# Tuning
WORKER_CONCURRENCY=1
MAX_RETRIES=3
RENDER_TIMEOUT_SECONDS=600
